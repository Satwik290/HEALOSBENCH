{
  "extends": "@test-evals/config/tsconfig.base.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@test-evals/env/*": ["../env/src/*"],
      "@test-evals/shared": ["../shared/src"]
    }
  },
  "include": ["src", "../env/src", "../shared/src"]
}
