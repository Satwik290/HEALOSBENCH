# HEALOSBENCH Server Environment Variables
# Copy this to .env and fill in the values

# Anthropic API Key for LLM extraction
ANTHROPIC_API_KEY=sk-ant-xxx

# Database Connection URL (Postgres)
# If using the provided docker-compose, this should match the settings there.
DATABASE_URL=postgres://postgres:postgres@localhost:5433/healosbench

# Authentication Secret (min 32 chars)
BETTER_AUTH_SECRET=a_very_long_random_string_at_least_32_chars_long

# Authentication URL (usually the server's own URL)
BETTER_AUTH_URL=http://localhost:8787

# CORS Origin (where the web app is running)
CORS_ORIGIN=http://localhost:3001

# Port for the server
PORT=8787
